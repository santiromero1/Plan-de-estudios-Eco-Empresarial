# Credenciales de Supabase (Settings → API).
# Copiá este archivo a .env.local y completá los valores.
# En Vercel/Netlify se cargan como Environment Variables.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Access key de Web3Forms (https://web3forms.com) para los mails de soporte.
# Es pública (va en el frontend). Si falta, los mensajes igual se guardan en Supabase.
VITE_WEB3FORMS_KEY=
